# xAI / Grok
XAI_API_KEY=
XAI_CHAT_MODEL=grok-4.3
XAI_VISION_MODEL=grok-4

# OpenAI JSON plan specification stage
OPENAI_API_KEY=
# Existing Vercel alias also supported:
OPEN_AI_KEY=
OPENAI_DESIGN_MODEL=gpt-5.1

# Renderer runtime
# The job worker must have Python 3 and Pillow available for scripts/render_plan.py.
PYTHON_RENDERER=enabled

# App
NEXT_PUBLIC_APP_URL=
ORCHESTRATOR_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
INSTALLER_TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=awolaibot
TELEGRAM_WEBHOOK_BASE_URL=
INSTALLER_WEBHOOK_BASE_URL=
TELEGRAM_SETUP_SECRET=
TELEGRAM_WEBHOOK_SECRET=

# Supabase
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_DB_PASSWORD=

# Optional job protection
JOB_SECRET=
CRON_SECRET=
