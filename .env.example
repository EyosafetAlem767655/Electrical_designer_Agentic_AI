# OpenAI analysis and JSON plan specification stages
OPENAI_API_KEY=
# Existing Vercel alias also supported:
OPEN_AI_KEY=
OPENAI_DESIGN_MODEL=gpt-5.5
OPENAI_ANALYSIS_MODEL=gpt-5.5

# Renderer runtime
# The job worker must have Python 3 and Pillow available for scripts/render_plan.py.
PYTHON_RENDERER=enabled
# Optional when your host uses a nonstandard executable name, e.g. python, python3, or /usr/bin/python3.
PYTHON_RENDERER_COMMAND=

# App
NEXT_PUBLIC_APP_URL=
ORCHESTRATOR_URL=
BACKEND_BASE_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
INSTALLER_TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=awolaibot
TELEGRAM_WEBHOOK_BASE_URL=
INSTALLER_WEBHOOK_BASE_URL=
TELEGRAM_SETUP_SECRET=
TELEGRAM_WEBHOOK_SECRET=

# Supabase
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_DB_PASSWORD=

# Optional job protection
JOB_SECRET=
CRON_SECRET=
